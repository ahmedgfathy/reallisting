# RealListing Environment Variables
# Copy this file to .env and fill in your values.
# For Vercel production, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# ── Supabase ────────────────────────────────────────────────────────────────
# Required for production (Vercel). When both are set, Supabase is used as the
# database instead of the local JSON file.

# Supabase project URL (found in Project Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in Project Settings → API → Project API keys)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Newer Supabase projects may expose a publishable key instead of the older anon key.
# You can set either SUPABASE_ANON_KEY or SUPABASE_PUBLISHABLE_KEY.
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional frontend-safe aliases. The backend also accepts these names when
# running in serverless environments that expose NEXT_PUBLIC_* variables.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional: Supabase service role key for elevated privileges (bypasses RLS).
# Use this if your RLS policies are restrictive and you need server-side writes.
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: secret used to sign auth tokens (defaults to built-in fallback)
# Keep JWT_SECRET and SUPABASE_JWT_SECRET aligned if you set both.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# JWT_SECRET=your-custom-jwt-secret

# ── Frontend ─────────────────────────────────────────────────────────────────
# API base URL used by the React frontend.
# In production this should point to your Vercel deployment.
REACT_APP_API_URL=https://your-vercel-app.vercel.app

# ── Optional features ────────────────────────────────────────────────────────
# AI-powered message classification via Google Gemini
# GEMINI_API_KEY=your-gemini-api-key

# Allowed CORS origins (comma-separated). Defaults include localhost and vercel.app.
# ALLOWED_ORIGINS=https://your-domain.com,https://your-vercel-app.vercel.app
